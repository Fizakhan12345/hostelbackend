# ════════════════════════════════════════════════
#   HOSTEL BOOKING PLATFORM — ENVIRONMENT CONFIG
#   Copy this file as .env and fill your values
# ════════════════════════════════════════════════

# ── SERVER ───────────────────────────────────────
PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Fizu@321456
DB_NAME=hostel_booking_db

# ── JWT SECRETS ──────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_for_users_min_64_chars
JWT_EXPIRES_IN=7d
JWT_ADMIN_SECRET=change_this_to_a_different_long_random_string_for_admins

# ── EMAIL (Gmail SMTP) ────────────────────────────
# For Gmail: enable 2FA → generate App Password at myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_char_gmail_app_password
EMAIL_FROM=Belapur Hostel <youremail@gmail.com>

# ── RAZORPAY PAYMENT GATEWAY ─────────────────────
# Get keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ── FILE UPLOADS ──────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
# 5242880 = 5MB in bytes

# ── COMMISSION SETTINGS ───────────────────────────
DEFAULT_COMMISSION_RATE=5
# 5 means 5% commission per booking

# ── FRONTEND URL (for CORS & email reset links) ───
FRONTEND_URL=http://localhost:4200
# Change to your deployed Angular URL in production
# FRONTEND_URL=https://belapur-hostel-fiza.vercel.app

# ── OTP SETTINGS ─────────────────────────────────
OTP_EXPIRES_MINUTES=10

# ── RATE LIMITING ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
# 900000 = 15 minutes
RATE_LIMIT_MAX_REQUESTS=100